<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.boyu.funding-agent.email</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/boyu/.local/bin/uv</string>
        <string>run</string>
        <string>python</string>
        <string>-m</string>
        <string>web.cli</string>
        <string>email-digest</string>
        <string>--due</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/boyu/funding-agent</string>
    <key>StartInterval</key>
    <integer>3600</integer>
    <key>StandardOutPath</key>
    <string>/Users/boyu/funding-agent/outputs/logs/cli-email.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/boyu/funding-agent/outputs/logs/cli-email.err.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/boyu/.local/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
