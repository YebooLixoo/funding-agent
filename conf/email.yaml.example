email:
  smtp_host: "smtp.gmail.com"
  smtp_port: 587
  use_tls: true
  # Credentials via GMAIL_ADDRESS and GMAIL_APP_PASSWORD env vars
  test_recipient: "your-email@example.com"
  recipients:
    - "user1@example.com"
    - "user2@example.com"
  subject_prefix: "Funding Digest"
  deadline_lookahead_days: 30
  digest_archive_dir: "outputs/digests"
  history_url: "https://yeboolixoo.github.io/funding-agent/"
  history_output_dir: "docs"
